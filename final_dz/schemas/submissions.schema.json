{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["student_id", "course_id", "assignment_id", "submitted_at"],
    "properties": {
      "student_id": {"bsonType": "int"},
      "course_id": {"bsonType": "int"},
      "assignment_id": {"bsonType": "int"},
      "submitted_at": {"bsonType": "date"},
      "status": {"enum": ["submitted", "late", "not_submitted", "reviewed"]},
      "grade": {"bsonType": "int", "minimum": 2, "maximum": 5},
      "feedback": {"bsonType": "string"},
      "file_url": {"bsonType": "string"}
    }
  }
}
